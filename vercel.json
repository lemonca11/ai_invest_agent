{
  "rewrites": [
    {
      "source": "/",
      "destination": "/site/index.html"
    },
    {
      "source": "/market",
      "destination": "/site/market/index.html"
    },
    {
      "source": "/market/",
      "destination": "/site/market/index.html"
    },
    {
      "source": "/earnings",
      "destination": "/site/earnings/index.html"
    },
    {
      "source": "/earnings/",
      "destination": "/site/earnings/index.html"
    },
    {
      "source": "/en",
      "destination": "/site/en/index.html"
    },
    {
      "source": "/en/",
      "destination": "/site/en/index.html"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/site/assets/$1"
    },
    {
      "source": "/feed.json",
      "destination": "/site/feed.json"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/site/$1"
    }
  ]
}
